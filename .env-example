DEBUG=False
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
PARSER_SERVICE_TOKEN=

# Логирование: DEBUG, INFO, WARNING, ERROR (по умолчанию INFO)
# LOG_LEVEL=DEBUG

# Celery (очередь задач для генерации маршрутов)
CELERY_BROKER_URL=redis://localhost:6379/0

# OpenRouter (LLM для тегирования и др.)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# Маршруты: 1 — не вызывать ИИ для оформления full_description (legacy-сборка HTML)
# ROUTE_DESCRIPTION_LEGACY=0
